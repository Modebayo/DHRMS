rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // User avatars - only owner can upload, everyone authenticated can read
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // User documents (medical records, reports)
    match /documents/{userId}/{documentName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }
    
    // Lab documents - medical staff can manage
    match /lab-documents/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024;
    }
    
    // Prescription documents
    match /prescription-docs/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024;
    }
    
    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}